# RetailGuard AI Configuration
# Copy to .env and fill in your values

# App
DEBUG=false
SECRET_KEY=generate-a-random-32-byte-hex-string

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://postgres:password@host:5432/retailguard

# Redis (Railway Redis)
REDIS_URL=redis://default:password@host:6379

# NVR Connection (Your Uniview Tec NR324XPC)
NVR_IP=192.168.1.100
NVR_PORT=554
NVR_USERNAME=admin
NVR_PASSWORD=your_nvr_password

# S3 Storage (optional, for cloud clip storage)
STORAGE_BACKEND=local
# S3_BUCKET=retailguard-clips
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# AI Tuning
FACE_MATCH_TOLERANCE=0.45
CONCEALMENT_CONFIDENCE_THRESHOLD=0.75
COMPOSITE_MATCH_THRESHOLD=0.72
